<%= @product_name %>-appliance
<%= @product_name %>-appliance-tools

epel-release

createrepo
fuse-libs

python3-devel                    # for building python modules in post
kernel
zipl
s390utils-base
s390utils-core
libguestfs
libguestfs-tools
python3-libguestfs
dracut-config-generic

<% if @target != "azure" && @target != "gce" %>
cloud-init
<% end %>

<% case @target
   when "azure" %>
WALinuxAgent
<% when "ec2" %>
dracut-config-generic
<% when "hyperv" %>
hyperv-daemons
<% when "libvirt", "ovirt" %>
qemu-guest-agent
<% when "vsphere" %>
open-vm-tools
<% when "gce" %>
google-guest-agent
<% end %>

<%= render_partial_if_exist "packages/includes-extra" %>
